<%= render SectionComponent.new(label: 'Access conditions') do %>
  <%= tag.dl do %>
    <% field_map.each do |fields| %>
      <% fields.each do |field| %>
        <%= tag.dt field.label %>
        <%= tag.dd auto_link(simple_format(field.values.join("\n\n")), html: { class: 'su-underline' }) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
