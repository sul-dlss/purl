<% label_id = "section-subjects" %>
<%= render SectionComponent.new(label: 'Subjects', label_id:) do %>
  <%= render TableComponent.new(label_id:) do %>
    <% if subject_display_data.present? %>
    <% subject_display_data.each do |field| %>
        <tbody>
          <%= render RowFieldComponent.new(field:) %>
        </tbody>
      <% end %>
    <% end %>
    <% if genre_display_data.present? %>
      <% genre_display_data.each do |field| %>
        <tbody>
          <%= render RowFieldComponent.new(field:) %>
        </tbody>
      <% end %>
    <% end %>
  <% end %>
<% end %>
